{
  "name": "touchvodka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Touch Vodka — spirits brand site rebuilt on the Vinny platform (Next.js + @vinny/foundation + @vinny/ui + @vinny/blocks). Migrated from a Vite/React build (T25 pilot).",
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check . && tsx scripts/preflight.ts --lint-only",
    "typecheck": "tsc --noEmit",
    "preflight": "tsx scripts/preflight.ts",
    "test": "playwright test",
    "test:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@vinny/foundation": "^0.1.0",
    "@vinny/ui": "^0.1.0",
    "gsap": "^3.12.5",
    "@gsap/react": "^2.1.1",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.546.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "react-simple-maps": "^3.0.0",
    "vanilla-cookieconsent": "^3.0.1",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-simple-maps": "^3.0.6",
    "@types/nodemailer": "^6.4.14",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@vinny/foundation": "link:../../vinny-platform/packages/foundation",
      "@vinny/ui": "link:../../vinny-platform/packages/ui"
    }
  }
}
