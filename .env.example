# ─────────────────────────────────────────────────────────────────────────────
# Touch Vodka — environment contract. Copy to .env.local for dev.
# Registry trap `prod-cms-url-not-localhost`: in prod these MUST be HTTPS hosts
# (no localhost, no port). Registry trap `no-secret-in-next-public`: anything
# NEXT_PUBLIC_ is shipped to the browser — never put a secret behind that prefix.
# ─────────────────────────────────────────────────────────────────────────────

# Content scope — this brand's key in the shared Strapi + the lead pipeline.
SITE_KEY=touch-vodka
NEXT_PUBLIC_SITE_KEY=touch-vodka

# Canonical site origin (no trailing slash) — drives @geniemarketing/seo canonical
# URLs, hreflang, sitemap, and JSON-LD. Defaults to https://touchvodka.com.
NEXT_PUBLIC_SITE_URL=https://touchvodka.com

# Shared Layer 0 backend (S6) — the ONE deployed multi-tenant Strapi, not per-site.
# NOTE: real host is marketing.fatdogspirits.com (NOT the scaffold's cms.vinny.agency
# stub). Tenants are isolated by the `client` enum; this brand's slug is touch-vodka.
NEXT_PUBLIC_STRAPI_URL=https://marketing.fatdogspirits.com
STRAPI_API_TOKEN=                       # TOUCH_VODKA_API_TOKEN — scoped, read-only
REVALIDATION_SECRET=                    # ISR webhook secret; Strapi posts /api/revalidate?secret=…

# Production-media tier (S5 / #7). Base URL for client-editable media (bottle/blog
# shots) so it's swappable without a deploy. UNSET → the local public/ statics are
# served (dev/preview + the pre-CDN live build). Set to the Strapi media host today;
# point at the img.fatdogspirits.com CloudFront/imgproxy edge once it lands (deferred —
# see projects/touchvodka-next/S5-WAVE2J-MEDIA-RUNBOOK.md). Host must be allow-listed
# in next.config.ts images.remotePatterns.
# NEXT_PUBLIC_MEDIA_BASE=https://marketing.fatdogspirits.com    # → CloudFront once edge is up

# DTC commerce (@geniemarketing/commerce, S4·I → S6/S3 + S10). Touch Vodka is
# brand-only today: lib/commerce.ts is env-gated on the publishable key, so until
# S6/S3 provisions a Medusa sales channel these stay UNSET and the storefront
# reads as "no commerce" (empty catalog, no Offer in Product JSON-LD) — never a
# cross-tenant read. S6/S3 sets these on the Amplify app at onboarding; S10 then
# builds the PLP/PDP/cart/checkout blocks on the seam.
# NEXT_PUBLIC_MEDUSA_URL=https://commerce.vinny.agency        # shared Medusa (config.ts default)
# NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=                          # pk_… — scopes the storefront to this channel
# MEDUSA_SALES_CHANNEL_ID=                                     # this brand's channel (search filter)
# NEXT_PUBLIC_MEDUSA_REGION_ID=                                # S10 cart: region for cart creation (optional; Medusa picks default if unset)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=                          # S10 checkout: pk_test_… (TEST) — Stripe Elements card step; unset → manual/test-order path
# NEXT_PUBLIC_MEILISEARCH_URL=https://search.vinny.agency      # shared Meilisearch (config.ts default)
# NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=                          # SEARCH-only key (public) — never the admin key

# Consent-gated analytics (S9 / #22) — CANONICAL path: RudderStack CDP → warehouse.
# Public write key is fine (it's a browser SDK key). The write key is WRITE_KEY_TOUCH
# (RudderStack source `touch-vodka`); the operator pulls it from SOPS
# (`sops -d security/secrets.prod.enc.env | grep WRITE_KEY_TOUCH`) and sets it on the
# Amplify app — do NOT commit the real value. Data plane = the live ingestion gateway.
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=
NEXT_PUBLIC_RUDDERSTACK_DATAPLANE=https://events.fatdogspirits.com

# PostHog (S7) — OPTIONAL future self-host; the dedicated box was never deployed
# (`warehouse up` shipped ClickHouse/Metabase/RudderStack/MinIO, not PostHog — see the
# PostHog-vs-CDP DECISION in sessions/HANDOFFS.md). Leave KEY empty: initPostHog no-ops
# and the CDP stream above is the live analytics path. Set it only if Vinny stands the
# box up. Host is the fleet-canonical t.fatdogspirits.com (old t.vinny.agency is dead).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://t.fatdogspirits.com

# Legacy GA / gtag (S7) — kept, but now gated behind marketing consent.
NEXT_PUBLIC_GA_ID=                      # e.g. G-XXXXXXX (was raw gtag in the Vite build)

# Leads → CRM/email (S8). The route handler is a thin proxy to the n8n webhook.
LEAD_WEBHOOK_URL=https://n8n.vinny.agency/webhook/lead
LEAD_WEBHOOK_SECRET=                    # x-lead-secret shared with the n8n flow
NEXT_PUBLIC_TURNSTILE_SITE_KEY=         # Cloudflare Turnstile (client widget)
TURNSTILE_SECRET=                       # server-side verify (NEVER NEXT_PUBLIC)

# Transactional email — migration (S8/T26). New path: SMTP2GO (SMTP, mail.smtp2go.com:587).
# Old path stays live until the new one is verified delivering (see LEARNINGS).
SMTP2GO_SMTP_HOST=mail.smtp2go.com
SMTP2GO_SMTP_PORT=587
SMTP2GO_SMTP_USER=                      # minted in SMTP2GO → Sending → SMTP Users
SMTP2GO_SMTP_PASSWORD=
EMAIL_PROVIDER=smtp2go                  # 'smtp2go' (new) | 'office365' (legacy fallback)
CONTACT_RECIPIENT_EMAIL=info@touchvodka.com

# Legacy Office 365 / nodemailer transport — fallback only, remove after cutover.
OFFICE365_EMAIL=
OFFICE365_APP_PASSWORD=

# GitHub Packages auth for @geniemarketing/* (read:packages). CI injects this.
# Local dev links to the workspace instead (see package.json pnpm.overrides).
NODE_AUTH_TOKEN=
